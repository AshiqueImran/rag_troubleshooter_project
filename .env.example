# ── LLM — Groq (active) ───────────────────────────────────────────────────────
# Sign up free at https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# ── LLM — OpenAI (alternative) ───────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

MAX_TOKENS=1024

# ── Embedding ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Knowledge source — pick ONE: documents | database | web ───────────────────
SOURCE_TYPE=documents

# If SOURCE_TYPE=documents
DOCUMENTS_DIR=data/documents

# If SOURCE_TYPE=database
DB_URL=postgresql://user:password@host:5432/dbname
DB_QUERY=SELECT id, title, content FROM knowledge_base

# If SOURCE_TYPE=web
WEB_URLS=https://example.com/docs,https://example.com/faq

# ── Storage ───────────────────────────────────────────────────────────────────
VECTOR_STORE_PATH=vector_store
LOG_PATH=logs/requests.jsonl

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
